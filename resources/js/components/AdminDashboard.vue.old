</template>

<script setup>
import { ref, onMounted } from 'vue';

const activeTab = ref('overview');
const dashboard = ref({
  total_users: 0,
  total_photographers: 0,
  active_bookings: 0,
  total_revenue: 0,
  recent_activity: [],
});

const users = ref([]);
const verifications = ref([]);
const auditLogs = ref([]);
const userSearch = ref('');

const fetchDashboard = async () => {
  try {
    const response = await fetch('/api/v1/admin/dashboard', {
      headers: {
        'Authorization': `Bearer ${localStorage.getItem('auth_token')}`,
      },
    });
    const data = await response.json();
    if (data.status === 'success') {
      dashboard.value = data.data;
    }
  } catch (error) {
    console.error('Error fetching dashboard:', error);
  }
};

const fetchUsers = async () => {
  try {
    const response = await fetch('/api/v1/admin/users', {
      headers: {
        'Authorization': `Bearer ${localStorage.getItem('auth_token')}`,
      },
    });
    const data = await response.json();
    if (data.status === 'success') {
      users.value = data.data;
    }
  } catch (error) {
    console.error('Error fetching users:', error);
  }
};

const fetchVerifications = async () => {
  try {
    const response = await fetch('/api/v1/admin/verifications', {
      headers: {
        'Authorization': `Bearer ${localStorage.getItem('auth_token')}`,
      },
    });
    const data = await response.json();
    if (data.status === 'success') {
      verifications.value = data.data;
    }
  } catch (error) {
    console.error('Error fetching verifications:', error);
  }
};

const fetchAuditLogs = async () => {
  try {
    const response = await fetch('/api/v1/admin/audit-logs', {
      headers: {
        'Authorization': `Bearer ${localStorage.getItem('auth_token')}`,
      },
    });
    const data = await response.json();
    if (data.status === 'success') {
      auditLogs.value = data.data;
    }
  } catch (error) {
    console.error('Error fetching audit logs:', error);
  }
};

const suspendUser = async (user) => {
  try {
    const response = await fetch(`/api/v1/admin/users/${user.id}/suspend`, {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${localStorage.getItem('auth_token')}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        reason: 'Admin action',
      }),
    });
    const data = await response.json();
    if (data.status === 'success') {
      user.is_suspended = true;
    }
  } catch (error) {
    console.error('Error suspending user:', error);
  }
};

const unsuspendUser = async (user) => {
  try {
    const response = await fetch(`/api/v1/admin/users/${user.id}/unsuspend`, {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${localStorage.getItem('auth_token')}`,
      },
    });
    const data = await response.json();
    if (data.status === 'success') {
      user.is_suspended = false;
    }
  } catch (error) {
    console.error('Error unsuspending user:', error);
  }
};

const formatDate = (date) => {
  return new Date(date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  });
};

onMounted(() => {
  fetchDashboard();
  fetchUsers();
  fetchVerifications();
  fetchAuditLogs();
});
</script>
