                <th class="px-4 py-2 text-left">Date</th>
              </tr>
            </thead>
            <tbody>
              <tr v-for="log in auditLogs" :key="log.id" class="border-b">
                <td class="px-4 py-2">{{ log.action }}</td>
                <td class="px-4 py-2">{{ log.admin?.name || 'System' }}</td>
                <td class="px-4 py-2 text-sm text-gray-600">{{ log.ip_address }}</td>
                <td class="px-4 py-2 text-sm text-gray-600">{{ formatDate(log.created_at) }}</td>
