      <!-- Users Tab -->
      <div v-if="activeTab === 'users'" class="bg-white rounded-lg shadow p-6">
        <h2 class="text-xl font-bold mb-4">Users</h2>
        <div class="mb-4">
          <input
            v-model="userSearch"
