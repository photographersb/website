# Files and Folders to EXCLUDE from Upload
# Do NOT upload these to production server

# ⚠️ CLEANUP FOLDER - ALL UNWANTED FILES ORGANIZED HERE
_CLEANUP_FILES/

# Development files
node_modules/
.git/
.github/
tests/
docs/
_archive_docs/
scripts/
.env
.env.testing
.env.example

# Build artifacts
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Documentation (optional - can upload if needed)
*.md
!README.md

# Development tools
.editorconfig
.gitignore
.gitattributes
phpunit.xml
webpack.mix.js

# Cache and temp files
storage/logs/*.log
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
bootstrap/cache/*.php
