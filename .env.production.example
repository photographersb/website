APP_NAME="Photographer SB"
APP_ENV=production
APP_KEY=base64:GENERATE_NEW_KEY_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://photographersb.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database Configuration - Update with your cPanel database details
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=photographersb_main
DB_USERNAME=photographersb_user
DB_PASSWORD=YOUR_STRONG_PASSWORD_HERE

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Mail Configuration - Use your domain email or SMTP service
MAIL_MAILER=smtp
MAIL_HOST=mail.photographersb.com
MAIL_PORT=587
MAIL_USERNAME=noreply@photographersb.com
MAIL_PASSWORD=YOUR_EMAIL_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@photographersb.com
MAIL_FROM_NAME="${APP_NAME}"

# Payment Gateways - Add your production keys
RAZORPAY_KEY=rzp_live_your_key_here
RAZORPAY_SECRET=your_secret_here

STRIPE_KEY=pk_live_your_key_here
STRIPE_SECRET=sk_live_your_secret_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Optional Services
FACEBOOK_APP_ID=
GOOGLE_CLIENT_ID=
